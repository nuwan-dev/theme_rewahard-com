{% doc %}
  @prompt
    give me html block . that works html inside. also give me this full width and boxed with switch in controls, container width should adjets to 1920 px. can be increase 10 by 10
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-html-block-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-html-block-container-{{ ai_gen_id }} {
    {% if block.settings.layout == 'boxed' %}
      max-width: {{ block.settings.container_width }}px;
      margin: 0 auto;
      padding: 0 20px;
    {% else %}
      width: 100%;
    {% endif %}
  }

  .ai-html-block-content-{{ ai_gen_id }} {
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-html-block-content-{{ ai_gen_id }} * {
    max-width: 100%;
  }

  .ai-html-block-content-{{ ai_gen_id }} img {
    height: auto;
  }

  @media screen and (max-width: 749px) {
    .ai-html-block-content-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px {{ block.settings.padding_horizontal_mobile }}px {{ block.settings.padding_bottom_mobile }}px;
    }
  }
{% endstyle %}

<custom-html-block-{{ ai_gen_id }} class="ai-html-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-html-block-container-{{ ai_gen_id }}">
    <div class="ai-html-block-content-{{ ai_gen_id }}">
      {% if block.settings.html_content != blank %}
        {{ block.settings.html_content }}
      {% else %}
        <div style="text-align: center; padding: 40px 20px; color: #999; font-style: italic;">
          Add your custom HTML content in the block settings
        </div>
      {% endif %}
    </div>
  </div>
</custom-html-block-{{ ai_gen_id }}>

<script>
  (function() {
    class CustomHtmlBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.executeScripts();
      }

      executeScripts() {
        const scripts = this.querySelectorAll('script');
        scripts.forEach((oldScript) => {
          const newScript = document.createElement('script');
          Array.from(oldScript.attributes).forEach((attr) => {
            newScript.setAttribute(attr.name, attr.value);
          });
          newScript.textContent = oldScript.textContent;
          oldScript.parentNode.replaceChild(newScript, oldScript);
        });
      }
    }

    customElements.define('custom-html-block-{{ ai_gen_id }}', CustomHtmlBlock{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Custom HTML",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "html",
      "id": "html_content",
      "label": "HTML content"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        {
          "value": "full_width",
          "label": "Full width"
        },
        {
          "value": "boxed",
          "label": "Boxed"
        }
      ],
      "default": "full_width"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 600,
      "max": 1920,
      "step": 20,
      "unit": "px",
      "label": "Container width",
      "default": 1200,
      "info": "Only applies when layout is set to Boxed"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Spacing - Desktop"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 20
    },
    {
      "type": "header",
      "content": "Spacing - Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top padding",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_horizontal_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 15
    }
  ],
  "presets": [
    {
      "name": "Custom HTML"
    }
  ]
}
{% endschema %}