      *,
      *::before,
      *::after {
      	box-sizing: inherit;
      }

      html {
      	box-sizing: border-box;
      	font-size: 10px;
      	height: 100%;
      }

      body {
      	position: relative;
      	display: grid;
      	grid-template-rows: auto auto 1fr auto;
      	grid-template-columns: 100%;
      	min-height: 100%;
      	margin: 0;
      	font-size: var(--font-body-size);
      	line-height: 1.5;
