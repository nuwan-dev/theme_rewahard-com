      {%- comment -%}Yoast SEO schema control block: start.{%- endcomment -%}
{%- assign yoast_seo_settings = shop.metafields.yoast_seo.settings.value | default: shop.metafields.yoast_seo.settings -%}
{%- if disabled_by_yoast_seo or yoast_seo_settings.schema.useTheme.schema or yoast_seo_settings.schema.useTheme.webpage -%}
<script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "What are the shipping fees for online orders?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "New Zealand: Orders are delivered with tracked Post Express. 1-3 business days $6.00 NZD Express shipping for Auckland, $10.00 NZD Express shipping for the rest of New Zealand. Free shipping on all orders $200 NZD and over.\n\nAustralia: $50 for tracked Post Express (4-8 business days), $25 for untracked Post Express (6-12 business days, at buyer’s risk).\n\nRest of the World: Please contact us by email."
              }
            },
            {
              "@type": "Question",
              "name": "When will my order ship/arrive?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "We work hard to deliver orders within the given timeframes. Peak trading times, holidays, and sales periods may impact delivery times. Please contact us if you have any questions about your order’s status."
              }
            },
            {
              "@type": "Question",
              "name": "What if I need to change my shipping address?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Contact us as soon as possible! Notification is required within 14 days for lost items. Claims outside this timeframe will be declined. Claims are processed within 30 working days, and you may be eligible for reimbursement or reshipment based on product availability."
              }
            },
            {
              "@type": "Question",
              "name": "My order arrived damaged, what do I do?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Contact us immediately! You must notify us within 7 days for a damaged item. Claims outside this timeframe will be declined. Claims are processed within 30 working days, and you may be eligible for reimbursement or reshipment based on product availability."
              }
            },
            {
              "@type": "Question",
              "name": "I moved! Can I update the shipping address on my order?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes! Contact us with your new address before your order is shipped, and we’ll update it. Changing the address on your account does not update existing orders, so please reach out to us directly."
              }
            },
            {
              "@type": "Question",
              "name": "How secure is online shopping? Is my data protected?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "We respect your privacy and only collect the necessary information to complete your order. We do not store credit card information and do not rent or sell your personal details."
              }
            },
            {
              "@type": "Question",
              "name": "What are my options for customer support?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "You can contact us via email at info@rewahard.com. Customer Support is available Monday – Friday (9am – 5pm NZT). We aim to respond to all queries within 24 business hours, though delays may occur during sale periods."
              }
            },
            {
              "@type": "Question",
              "name": "What is your returns policy?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "We do not provide refunds for change-of-mind purchases, so please choose carefully. If a product is faulty, we will provide a remedy as required by the Consumer Guarantees Act. For assistance, you can contact the Consumer Protection helpline at 0508 426 678."
              }
            }
          ]
        }
      {%- comment -%}Yoast SEO schema control block: end.{%- endcomment -%}
