<div class="container" style="margin-top:20px;">
  <a href="{{ section.settings.button_link}}">
    <img
      class="custom-desktop-image"
      src="{{ section.settings.image_desktop | image_url: height: 470 }}"
      width="100%"
    >
    <img
      class="custom-mobile-image"
      src="{{ section.settings.image_mobile | image_url: height: 270}}"
      width="100%"
    >
  </a>
</div>

{% schema %}
{
  "name": "BruceBanner",
  "tag": "section",
  "class": "spaced-section",
  "settings": [
    {
        "type": "image_picker",
        "id": "image_desktop",
        "label": "image_desktop"
    },
    {
        "type": "image_picker",
        "id": "image_mobile",
        "label": "image_mobile"
    },
    {
			"type": "url",
			"id": "button_link",
			"label": "t:sections.all.button.link.label"
		},
  ],
  "presets": [
    {
      "name": "BruceBanner"
    }
  ]
}
{% endschema %}
