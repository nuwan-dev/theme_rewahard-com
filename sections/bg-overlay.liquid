{% schema %}
{
  "name": "Bg Overlay",
  "tag": "section",
  "class": "background-overlay-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.5
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (H2)",
      "default": "REWACLUB REWARDS PROGRAM"
    },
    {
      "type": "textarea",
      "id": "paragraph",
      "label": "Paragraph",
      "default": "Joining RewaClub earns loyalty points on every purchase, which can be redeemed toward future orders."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "JOIN NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Background Color",
      "default": "#ff0000"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Top Margin (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Bottom Margin (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    },
    {
      "type": "text",
      "id": "section_padding",
      "label": "Section Padding (CSS shorthand)",
      "default": "60px 20px"
    },
    {
      "type": "text",
      "id": "section_padding_mobile",
      "label": "Section Padding (Mobile, CSS shorthand)",
      "default": "40px 16px"
    },
    {
      "type": "range",
      "id": "heading_font_mobile",
      "label": "Heading Font Size (Mobile, px)",
      "min": 12,
      "max": 100,
      "step": 1,
      "default": 48
    },
    {
      "type": "range",
      "id": "button_font_mobile",
      "label": "Button Font Size (Mobile, px)",
      "min": 12,
      "max": 48,
      "step": 1,
      "default": 18
    }
  ],
  "presets": [
    {
      "name": "Background Overlay Section"
    }
  ]
}
{% endschema %}

{% style %}
.background-overlay-{{ section.id }} {
  position: relative;
  background-image: url({{ section.settings.bg_image | image_url }});
  background-size: cover;
  background-position: center;
  margin-top: {{ section.settings.margin_top }}px;
  margin-bottom: {{ section.settings.margin_bottom }}px;
  color: {{ section.settings.text_color }};
}

.background-overlay-{{ section.id }}::before {
  content: "";
  position: absolute;
  inset: 0;
  background-color: {{ section.settings.overlay_color }};
  opacity: {{ section.settings.overlay_opacity }};
  z-index: 1;
}

.background-overlay-{{ section.id }} .container {
  position: relative;
  z-index: 2;
  margin: 0 auto;
  padding: {{ section.settings.section_padding }};
}

.background-overlay-{{ section.id }} .content {
  text-align: left;
}

.background-overlay-{{ section.id }} .content h2 {
  color: {{ section.settings.heading_color }};
  margin-bottom: 20px;
  font-size: 100px;
}

.background-overlay-{{ section.id }} .content p {
  margin-bottom: 30px;
}

.background-overlay-{{ section.id }} .content a.button {
  background-color: {{ section.settings.button_color }};
  color: #fff;
  font-size: 24px;
  padding: 10px 24px;
  text-decoration: none;
  border-radius: 0px;
  display: inline-block;
  margin-top: 20px;
}

/* Mobile overrides */
@media screen and (max-width: 768px) {
  .background-overlay-{{ section.id }} .container {
    padding: {{ section.settings.section_padding_mobile }};
  }

  .background-overlay-{{ section.id }} .content h2 {
    font-size: {{ section.settings.heading_font_mobile }}px;
  }

  .background-overlay-{{ section.id }} .content a.button {
    font-size: {{ section.settings.button_font_mobile }}px;
  }
}
{% endstyle %}

<div class="background-overlay-section background-overlay-{{ section.id }}">
  <div class="container">
    <div class="content">
      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.paragraph != blank %}
        <p>{{ section.settings.paragraph }}</p>
      {% endif %}
      {% if section.settings.button_label != blank and section.settings.button_link != blank %}
        <a href="{{ section.settings.button_link }}" class="button">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>
  </div>
</div>
