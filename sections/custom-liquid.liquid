      <svg
        width="40px"
        height="80px"
        viewBox="-19.04 0 75.804 75.804"
        xmlns="http://www.w3.org/2000/svg"
      >
        <g
          id="Group_65"
          data-name="Group 65"
          transform="translate(-831.568 -384.448)"
        >
          <path
