<!-- sections/custom-promo.liquid -->
<style>

  .promo-banner-wrapper {
    display: flex;
    flex-wrap: wrap;
  }

  .promo-left,
  .promo-right {
    width: 50%;
  }

  @media screen and (max-width: 768px) {
    .promo-left,
    .promo-right {
      width: 100% !important;
    }

    .promo-banner-wrapper .top-text     { font-size: {{ section.settings.top_text_size_mobile }}px !important; margin: {{ section.settings.top_text_margin_mobile }}!important; }
    .promo-banner-wrapper .secondary    { font-size: {{ section.settings.secondary_text_size_mobile }}px !important; margin: {{ section.settings.secondary_text_margin_mobile }}!important; }
    .promo-banner-wrapper .main-heading { font-size: {{ section.settings.main_heading_size_mobile }}px !important; margin : {{ section.settings.main_heading_margin_mobile }}!important; }
    .promo-banner-wrapper .paragraph    { font-size: {{ section.settings.paragraph_size_mobile }}px !important; margin: {{ section.settings.paragraph_margin_mobile }}!important; }
    .promo-banner-wrapper .cta-button   { font-size: {{ section.settings.button_text_size_mobile }}px !important; margin: {{ section.settings.button_text_margin_mobile }}!important; }

     .promo-left-inner {
    position: relative !important;
    height: auto !important;
  }

  .promo-left-inner img {
    height: auto !important;
  }
  }

  .promo-banner-wrapper .top-text {
  display: inline-block;
  background-color: {{ section.settings.top_text_bg_color }};
  color: {{ section.settings.top_text_color }};
  padding: {{ section.settings.top_text_padding }};
  border-radius: {{ section.settings.top_text_radius }}px;
  font-size: {{ section.settings.top_text_size }}px;
  font-weight: {{ section.settings.top_text_weight }};
  margin: {{ section.settings.top_text_margin }};
  text-align: center;
}

@media screen and (max-width: 768px) {
  .promo-banner-wrapper .top-text {
    font-size: {{ section.settings.top_text_size_mobile }}px;
    padding: {{ section.settings.top_text_padding_mobile }};
    margin: {{ section.settings.top_text_margin_mobile }};
  }
}


</style>

<div class="promo-banner-wrapper" style="display: flex; flex-wrap: wrap;">
  <div class="promo-left" style="width: 50%; position: relative;">
    <div class="promo-left-inner" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;">
      {% if section.settings.left_image %}
        <img src="{{ section.settings.left_image | img_url: 'master' }}" alt="Promo Image" style="width: 100%; height: 100%; object-fit: cover;" />
      {% endif %}
    </div>
  </div>


  <div class="promo-right" style="width: 50%; display: flex; align-items: center; justify-content: center; background-color: {{ section.settings.bg_color }}; background-image: url({{ section.settings.bg_image | img_url: 'master' }}); background-size: cover; background-position: center; padding: 2rem;">
    <div style="text-align: center; max-width: 500px; font-family: 'Koulen', sans-serif;">
      {% if section.settings.top_text %}
        <p class="top-text" style="color: {{ section.settings.top_text_color }}; font-size: {{ section.settings.top_text_size }}px; margin: {{ section.settings.top_text_margin }};">
          {{ section.settings.top_text }}
        </p>
      {% endif %}

      {% if section.settings.secondary_text %}
        <h3 class="secondary" style="color: {{ section.settings.secondary_text_color }}; font-size: {{ section.settings.secondary_text_size }}px; margin: {{ section.settings.secondary_text_margin }};">
          {{ section.settings.secondary_text }}
        </h3>
      {% endif %}

      {% if section.settings.main_heading %}
        <h2 class="main-heading" style="color: {{ section.settings.main_heading_color }}; font-size: {{ section.settings.main_heading_size }}px; margin: {{ section.settings.main_heading_margin }};">
          {{ section.settings.main_heading }}
        </h2>
      {% endif %}

      {% if section.settings.paragraph %}
        <p class="paragraph" style="color: {{ section.settings.paragraph_color }}; font-size: {{ section.settings.paragraph_size }}px; margin: {{ section.settings.paragraph_margin }};">
          {{ section.settings.paragraph }}
        </p>
      {% endif %}

      {% if section.settings.button_text %}
        <a class="cta-button" href="{{ section.settings.button_link }}" style="display: inline-block;padding: 0.75rem 1.5rem; background-color: {{ section.settings.button_color }}; color: {{ section.settings.button_text_color }}; text-decoration: none; border-radius: 0px; font-size: {{ section.settings.button_text_size }}px; margin: {{ section.settings.button_text_margin }};">
          {{ section.settings.button_text }} →
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
