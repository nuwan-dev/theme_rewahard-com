{{ 'ticker.css' | asset_url | stylesheet_tag }}

<script src="{{ 'ticker.js' | asset_url }}" defer="defer"></script>
{% style %}
  {% render 'spaced-section' %}
  {% render 'spaced-section-inner' %}
{% endstyle %}
<div
  class="
    ticker
    {% if section.settings.color_scheme == "light" %}color-background-2{% elsif section.settings.color_scheme == 'dark' %}color-background-4{% endif %}
  "
  data-date="{{ section.settings.date_picker }}"
  data-ticker-speed="{{ section.settings.ticker_speed }}"
  data-ticker-id="{{ section.id }}"
>
  <div class="swiper container ticker-js-{{ section.id }}">
    <div class="swiper-wrapper">
      {%- if section.settings.ticker_text_1 != blank or section.settings.ticker_text_2 != blank -%}
        {% for i in (1..5) %}
          <div class="swiper-slide">
            {%- if section.settings.ticker_text_1 != blank -%}
              <div
                class="ticker_box"
                style="background-color: black; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px"
              >
                <div class="ticker__title">
                  <p class="ticker__title-text h6" style=" color: #fff; font-size: {{ section.settings.ticker_font }}px ">
                    {{ section.settings.ticker_text_1 }}
                  </p>
                </div>
              </div>
            {%- endif -%}

            {%- if section.settings.ticker_text_2 != blank -%}
              <div
                class="ticker_box"
                style="background-color:rgb(252, 191, 2) !important; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px"
              >
                {% comment %} 
                  href="{{ section.settings.external_link }}"
                > {% endcomment %}
                  <div class="ticker__title">
                    <p class="ticker__title-text h6" style="color: #000000; font-size: {{ section.settings.ticker_font }}px">
                      {{ section.settings.ticker_text_2 }}
                    </p>
                  </div>
                {% comment %} </a> {% endcomment %}
              </div>
            {%- endif -%}
          </div>
        {% endfor %}
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
	"name": "double_tickers",
	"tag": "section",
	"class": "ticker-section",
	"enabled_on": {
    "templates": ["*"]
  },
	"settings": [
		{
			"type": "select",
			"id": "color_scheme",
			"label": "t:sections.all.color_scheme.label",
			"default": "light",
			"options": [
				{
					"value": "light",
					"label": "t:sections.all.color_scheme.light.label"
				},
				{
					"value": "dark",
					"label": "t:sections.all.color_scheme.dark.label"
				}
			]
		},
		{
			"type": "inline_richtext",
			"id": "ticker_text_1",
			"default": "Some text",
			"label": "ticker text 1"
		},
        {
			"type": "inline_richtext",
			"id": "ticker_text_2",
			"default": "Some text",
			"label": "ticket text 2"
		},
        {
            "type": "url",
            "id": "external_link",
            "label": "external_link for ticket text 2"
        },
		{
			"type": "range",
			"id": "ticker_speed",
			"min": 0,
			"max": 6,
			"step": 0.1,
			"default": 5,
			"unit": "s",
			"label": "t:sections.ticker.settings.ticker_speed.label"
		},
		{
			"type": "range",
			"id": "ticker_font",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"label": "t:sections.ticker.settings.ticker_font.label",
			"default": 14
		},
		{
			"type": "header",
			"content": "t:sections.all.section_padding.header.content"
		},
		{
			"type": "range",
			"id": "padding_top",
			"min": 0,
			"max": 200,
			"step": 10,
			"default": 20,
			"unit": "px",
			"label": "t:sections.all.section_padding.padding_top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom",
			"min": 0,
			"max": 200,
			"step": 10,
			"default": 20,
			"unit": "px",
			"label": "t:sections.all.section_padding.padding_bottom.label"
		},
		{
			"type": "header",
			"content": "t:sections.all.section_margin.header.content"
		},
		{
			"type": "range",
			"id": "margin_top",
			"min": 0,
			"max": 200,
			"step": 10,
			"default": 0,
			"unit": "px",
			"label": "t:sections.all.section_margin.margin_top.label"
		},
		{
			"type": "range",
			"id": "margin_bottom",
			"min": 0,
			"max": 200,
			"step": 10,
			"default": 0,
			"unit": "px",
			"label": "t:sections.all.section_margin.margin_bottom.label"
		}
	],
	"presets": [
		{
			"name": "t:sections.ticker.presets.name"
		}
	]
}
{% endschema %}
