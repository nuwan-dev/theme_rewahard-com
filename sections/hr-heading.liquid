{% schema %}
{
  "name": "HR Heading",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Text",
      "default": "Your Text Here"
    },
    {
      "type": "range",
      "id": "font_size_desktop",
      "label": "Heading Font Size (Desktop, px)",
      "min": 12,
      "max": 100,
      "step": 1,
      "default": 32
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "label": "Heading Font Size (Mobile, px)",
      "min": 12,
      "max": 100,
      "step": 1,
      "default": 24
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Line Color",
      "default": "#e0e0e0"
    },
    {
      "type": "range",
      "id": "line_thickness",
      "label": "Line Thickness (px)",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "padding_gap",
      "label": "Padding Between Text and Line (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    },
    {
      "type": "text",
      "id": "margin_desktop",
      "label": "Margin (Desktop) — top right bottom left",
      "default": "40px 0px 40px 0px"
    },
    {
      "type": "text",
      "id": "margin_mobile",
      "label": "Margin (Mobile) — top right bottom left",
      "default": "24px 0px 24px 0px"
    },
    {
      "type": "text",
      "id": "padding_desktop",
      "label": "Padding (Desktop) — top right bottom left",
      "default": "0px 0px 0px 0px"
    },
    {
      "type": "text",
      "id": "padding_mobile",
      "label": "Padding (Mobile) — top right bottom left",
      "default": "0px 0px 0px 0px"
    }
  ],
  "presets": [
    {
      "name": "HR Heading",
      "category": "Text"
    }
  ]
}
{% endschema %}

<div class="hr-heading-section">
  <div class="hr-line"></div>
  <h2 class="hr-text">{{ section.settings.heading }}</h2>
  <div class="hr-line"></div>
</div>

<style>
.hr-heading-section {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: {{ section.settings.padding_gap }}px;
  width: 100%;
  margin: {{ section.settings.margin_desktop }};
  padding: {{ section.settings.padding_desktop }};
}

.hr-text {
  margin: 0;
  font-weight: 400;
  white-space: nowrap;
  font-size: {{ section.settings.font_size_desktop }}px;
}

.hr-line {
  flex-grow: 1;
  height: {{ section.settings.line_thickness }}px;
  background-color: {{ section.settings.line_color }};
}

/* Mobile overrides */
@media screen and (max-width: 768px) {
  .hr-heading-section {
    margin: {{ section.settings.margin_mobile }};
    padding: {{ section.settings.padding_mobile }};
  }

  .hr-text {
    font-size: {{ section.settings.font_size_mobile }}px;
  }
}
</style>
