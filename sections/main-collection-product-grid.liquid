{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-loading-overlay.css' | asset_url | stylesheet_tag }}
{%- if settings.pagination_type == 'load_more' or settings.pagination_type == 'infinite_scroll' -%}
  <script src="{{ 'load-more.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
  {{ 'component-facets.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'facets-menu.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  {% render 'spaced-section' %}
{%- endstyle -%}

<style>
    @media only screen and (max-width: 768px) {
    #marsello-area {
      display: none;
    }
  }
</style>

<style>
  .rp-badge-img {
  position: absolute;
  top: -5rem;
  left: -5rem;
  z-index: 3;
  width: 184px;       /* adjust as you like */
  height: auto;
  pointer-events: none; /* click-through */
  display: block;
  }
  @media only screen and (max-width: 768px) {
  	.rp-badge-img {
  	width: 108px;       /* adjust as you like */
  	height: auto;
  	top: -3rem;
  	left: -3rem;
  	}
  }
</style>

<!-- begin: sub collections -->
<style>
  .sub-collection-container {
    position: relative;
    width: 100%;
    overflow: hidden; /* 隐藏溢出内容 */
    display: flex;
    align-items: center;
  }

  .sub-collection-slider {
    display: flex;
    overflow-x: auto;
    scroll-behavior: smooth; /* 平滑滚动效果 */
    scrollbar-width: none; /* 隐藏滚动条 (适用于 Firefox) */
    -ms-overflow-style: none; /* 隐藏滚动条 (适用于 IE 10+) */
  }

  .sub-collection-slider::-webkit-scrollbar {
    display: none; /* 隐藏滚动条 (适用于 Chrome, Safari) */
  }

  .collection-item {
    min-width: 100px; /* 设置每个子集合的最小宽度 */
    max-width: 208px;
    margin-right: 15px;
    flex-shrink: 0; /* 防止子元素收缩 */
    text-align:center;
  }
    .collection-item-img-div {
      border-radius: 50%; /* 将图片变成圆形 */
      padding: 5px;
  	background: linear-gradient(45deg, #d91568, #ffc400);
    }

    .collection-item-img {
      width: 195px; /* 圆形的直径 */
      height: 195px; /* 圆形的直径 */
      object-fit: cover; /* 保持图片不变形，剪裁内容 */
      border-radius: 50%; /* 将图片变成圆形 */
      overflow: hidden; /* 确保内容不溢出 */
      display: block; /* 确保图片为块级元素 */
      border: 6px solid #fff;

    }
    .collection-item-img:hover{
      border: 4px solid #fff;
    }

  .scroll-btn {
    position: absolute;
    top: 40%;
    transform: translateY(-50%);
    background-color: rgba(0, 0, 0, 0.5);
    color: white;
    border: none;
    padding: 10px;
    cursor: pointer;
    z-index: 100;
    display: none; /* 初始状态下隐藏 */
  }

  .left-btn {
    left: 5px; /* 避免按钮紧贴边缘，可以根据需要调整 */
  }

  .right-btn {
    right: 5px; /* 避免按钮紧贴边缘，可以根据需要调整 */
  }

    @media only screen and (max-width: 768px) {
      .collection-item-img-div{
        padding: 3px;
      }

      .collection-item-img {
        width: 84px;
        height: 84px;
        border: 3px solid #fff;
      }
      .collection-item {
        min-width: 80px;
        max-width: 90px;
        margin-right:10px;
        font-size: 12px;
        text-align:center;
      }

      .collection-item p {
        width:90px;
        line-height:20px;
        font-size:11px;
      }
      .scroll-btn {
        top: 30%;
      }
    }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const slider = document.querySelector('.sub-collection-slider');
    const leftBtn = document.querySelector('.left-btn');
    const rightBtn = document.querySelector('.right-btn');

    // 根据窗口宽度确定滚动距离
    function getScrollAmount() {
      // 如果屏幕宽度小于或等于768px，认为是手机端
      return window.innerWidth <= 768 ? 200 : 400;
    }

    function updateButtons() {
      if (slider.scrollLeft > 0) {
        leftBtn.style.display = 'block';
      } else {
        leftBtn.style.display = 'none';
      }

      if (Math.ceil(slider.scrollLeft + slider.clientWidth) < slider.scrollWidth) {
        rightBtn.style.display = 'block';
      } else {
        rightBtn.style.display = 'none';
      }
    }

    updateButtons();

    slider.addEventListener('scroll', updateButtons);

    window.addEventListener('resize', updateButtons);

    leftBtn.addEventListener('click', function () {
      slider.scrollBy({
        left: -getScrollAmount(), // 根据设备类型获取滚动距离
        behavior: 'smooth',
      });
    });

    rightBtn.addEventListener('click', function () {
      slider.scrollBy({
        left: getScrollAmount(), // 根据设备类型获取滚动距离
        behavior: 'smooth',
      });
    });
  });
</script>

{% assign collection_handles = collection.metafields.custom.sub_collections | split: ',' %}

<div class="container" style="margin-bottom:20px;">
  <div class="sub-collection-container">
    <button class="scroll-btn left-btn">←</button>
    <div class="sub-collection-slider">
      {% for handle in collection_handles %}
        {% assign sub_collection = collections[handle] %}
        {% if sub_collection %}
          <div class="collection-item">
            <a href="{{ sub_collection.url }}">
              <div class="collection-item-img-div">
                <img
                  src="{{ sub_collection.featured_image | img_url: 'medium' }}"
                  class="collection-item-img"
                  alt="{{ sub_collection.title }}"
                >
              </div>
              <p>{{ sub_collection.title }}</p>
            </a>
          </div>
        {% endif %}
      {% endfor %}
    </div>
    <button class="scroll-btn right-btn">→</button>
  </div>
</div>

{% if section.settings.enable_external_filtering %}
  {% render 'external-filter' %}
{% endif %}

<!-- end: sub collections -->

{%- if collection.all_products_count > 0 -%}
  {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
    <div class="facets__main">
      {% render 'facets',
        results: collection,
        enable_filtering: section.settings.enable_filtering,
        enable_sorting: section.settings.enable_sorting,
        taypes_position: section.settings.taypes_position
      %}
    </div>
  {%- endif -%}
{%- endif -%}

<!-- code for og culture page -->
{% if collection.handle == 'all-og-culture'
  or collection.handle == 'og-graphic-tees'
  or collection.handle == 'air-fresheners'
%}
  <!-- Google Tag Manager (noscript) -->
  <noscript
    ><iframe
      src="https://www.googletagmanager.com/ns.html?id=GTM-5XKKSPT"
      height="0"
      width="0"
      style="display:none;visibility:hidden"
    ></iframe
  ></noscript>
  <!-- End Google Tag Manager (noscript) -->
{% endif %}

<div
  id="ProductGridContainer"
  class="section-{{ section.id }}-padding collection__main-wrapper"
>
  {%- paginate collection.products by section.settings.products_per_page -%}
    {%- if collection.products.size == 0 -%}
      <div
        class="collection collection-product collection--empty container"
        id="product-grid"
        data-id="{{ section.id }}"
      >
        <div class="loading-overlay">
          <div class="loading-overlay__spinner">
            <svg
              aria-hidden="true"
              focusable="false"
              role="presentation"
              class="spinner"
              viewBox="0 0 66 66"
              xmlns="http://www.w3.org/2000/svg"
            >
              <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
            </svg>
          </div>
        </div>
        <div class="title-wrapper center title-wrapper-empty">
          <h2 class="title title--primary">
            {% if collection.all_products_count == 0 %}
              {{ 'sections.collection_template.empty' | t -}}
              <br>
              {{
                'sections.collection_template.use_fewer_filters_html'
                | t: link: routes.collections_url, class: 'underlined-link link'
              }}
            {% else %}
              {{ 'sections.collection_template.empty_results' | t -}}
              <br>
              {{
                'sections.collection_template.results_use_fewer_filters_html'
                | t: link: collection.url, class: 'underlined-link link'
              }}
            {% endif %}
          </h2>
        </div>
      </div>
    {%- else -%}
      <div class="collection collection-product container">
        <div class="loading-overlay">
          <div class="loading-overlay__spinner">
            <svg
              aria-hidden="true"
              focusable="false"
              role="presentation"
              class="spinner"
              viewBox="0 0 66 66"
              xmlns="http://www.w3.org/2000/svg"
            >
              <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
            </svg>
          </div>
        </div>
        {% style %}
          #product-grid {
          	--per-row : {{ section.settings.per_row }}
          }
        {% endstyle %}
        <div
          id="product-grid"
          data-id="{{ section.id }}"
          class="collection-product-list load-more-grid"
        >
          {%- for product in collection.products -%}
            {% if section.blocks.size > 0 %}
              {%- if forloop.index == 5 and forloop.length >= 6 -%}
                <!-- inserted tile between item[5] and item[6] -->
                <div class="collection-product-card promo-tile" style="margin:0; padding:0">
                  {%- for block in section.blocks -%}
                    {% render block %}
                  {%- endfor -%}
                </div>
              {%- endif -%}
            {%- endif -%}
            {% liquid
              assign condition = paginate.current_offset | plus: forloop.index | modulo: section.settings.per_row
              if condition == 0
                assign block_class = 'hide_border'
              else
                assign block_class = ''
              endif
            %}
            <div class="collection-product-card {% if settings.quickview_hover %}quickview--hover{% endif %} {{ block_class }}">
              {%- if product.tags contains 'customizable-back-print' -%}
                <img
                  class="rp-badge-img"
                  src="{{ 'custom-badge.png' | file_url }}"
                  srcset="{{ 'custom-badge.png' | file_url }} 1x, {{ 'custom-badge@2x.png' | file_url }} 2x"
                  alt=""
                  role="presentation"
                  aria-hidden="true"
                  loading="lazy"
                  decoding="async"
                >
              {%- endif -%}
              {% render 'product-card',
                product_card_product: product,
                media_size: section.settings.image_ratio,
                media_fit: section.settings.image_fit,
                show_secondary_image: section.settings.show_secondary_image,
                show_vendor: section.settings.show_vendor,
                show_desc: section.settings.show_desc,
                section_id: section.id
              %}
            </div>
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          {%- if settings.pagination_type == 'load_more' -%}
            {% render 'load-more',
              next_url: paginate.next.url,
              count_pages: paginate.pages,
              current_page: paginate.current_page
            %}
            <div class="js-hidden">
              {% render 'pagination', paginate: paginate %}
            </div>
          {%- elsif settings.pagination_type == 'infinite_scroll' -%}
            {% render 'infinite-scroll',
              next_url: paginate.next.url,
              count_pages: paginate.pages,
              current_page: paginate.current_page
            %}
            <div class="js-hidden">
              {% render 'pagination', paginate: paginate %}
            </div>
          {% else %}
            {% render 'pagination', paginate: paginate %}
          {%- endif -%}
        {%- endif -%}
      </div>
    {%- endif -%}
  {%- endpaginate -%}
</div>

{% schema %}
{
  "name": "t:sections.main-collection-product-grid.name",
  "tag": "section",
  "class": "collection-grid-section",
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 6,
      "max": 23,
      "step": 1,
      "default": 9,
      "label": "t:sections.main-collection-product-grid.settings.products_per_page.label"
    },
    {
      "type": "range",
      "id": "per_row",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "t:sections.all.column_per_row.label",
      "info": "t:sections.all.column_per_row.info"
    },
    {
      "type": "select",
      "id": "taypes_position",
      "default": "in_header",
      "label": "t:sections.main-collection-product-grid.settings.taypes_position.label",
      "options": [
        {
          "value": "in_menu",
          "label": "t:sections.main-collection-product-grid.settings.taypes_position.options__1.label"
        },
        {
          "value": "in_header",
          "label": "t:sections.main-collection-product-grid.settings.taypes_position.options__2.label"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.all.product_card.header.content"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": false,
      "label": "t:sections.all.product_card.show_secondary_image.label"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": true,
      "label": "t:sections.all.product_card.show_vendor.label"
    },
    {
      "type": "checkbox",
      "id": "show_desc",
      "default": false,
      "label": "t:sections.all.product_card.show_description.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.image.header.content"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "landscape",
          "label": "t:sections.all.image.ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.all.image.ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.all.image.ratio.options__3.label"
        }
      ],
      "default": "portrait",
      "label": "t:sections.all.image.ratio.label"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "t:sections.all.image.fit.label",
      "options": [
        {
          "value": "contain",
          "label": "t:sections.all.image.fit.options__1.label"
        },
        {
          "value": "cover",
          "label": "t:sections.all.image.fit.options__2.label"
        }
      ],
      "default": "cover"
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-product-grid.settings.header__1.content"
    },
    {
      "type": "checkbox",
      "id": "enable_external_filtering",
      "default": false,
      "label": "Enable external filter"
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "default": true,
      "label": "t:sections.main-collection-product-grid.settings.enable_filtering.label",
      "info": "t:sections.main-collection-product-grid.settings.enable_filtering.info"
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "default": true,
      "label": "t:sections.main-collection-product-grid.settings.enable_sorting.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section_margin.header.content"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 0,
      "unit": "px",
      "label": "t:sections.all.section_margin.margin_top.label"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 0,
      "unit": "px",
      "label": "t:sections.all.section_margin.margin_bottom.label"
    }
  ]
}
{% endschema %}
