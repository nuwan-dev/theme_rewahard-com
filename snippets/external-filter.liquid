<style>
  .select__external_filter{
    width:24%;
    height:3rem;
    font-family: "Koulen";
    font-size: 14px;
    font-weight: 400;
    letter-spacing:0.7px;
  }
  .filter__item{
    padding: 14px 0;  
  }
  @media screen and (min-width: 750px){
    .select__external_filter{
      width:12%;
    }

    .filter__item{
      padding: 20px 0;  
    }
  }
</style>

<div class="filter__wrapper">
  <div class="container">
    <div class="filter__item">
      {%- assign current_sort = request.params.sort_by | default: '' -%}

      <select
        name="quick_sort"
        class="select__external_filter"
        id="ExternalFilter"
        aria-describedby="a11y-refresh-page-message"
      >
        <option
          value="best-selling"
          {% if current_sort == 'best-selling' %}
            selected="selected"
          {% endif %}
        >
          best seller
        </option>

        <option
          value="created-descending"
          {% if current_sort == 'created-descending' %}
            selected="selected"
          {% endif %}
        >
          new arrival
        </option>
      </select>
    </div>
  </div>
</div>

<script>
  (function () {
    var select = document.getElementById('ExternalFilter');
    if (!select) return;

    // Ensure the dropdown reflects the current URL param (extra safety if Liquid didn't set it)
    var params = new URLSearchParams(window.location.search);
    var current = params.get('sort_by');
    if (current) {
      for (var i = 0; i < select.options.length; i++) {
        if (select.options[i].value === current) {
          select.value = current;
          break;
        }
      }
    }

    // Change handler: update URL, keep other filters, and reset pagination
    select.addEventListener('change', function (e) {
      var url = new URL(window.location.href);
      url.searchParams.set('sort_by', e.target.value);
      url.searchParams.delete('page');
      window.location.assign(url.toString());
    });
  })();
</script>
